{
  "App": {
    "DbConnectionString": "Host=postgres;Port=5432;Username=postgres;Password=myhome1861;Database=BookArchiveDb",
    "DbConnectionStringReport": "Host=postgres-reports;Port=5432;Username=postgres;Password=myhome1861;Database=reports",
    "Redis": {
      "RedisCacheConnection": "redis:6379",
      "RedisCachePrefix": "library:",
      "Books": {
        "BooksList": {
          "Prefix": "books:list",
          "TtlInMinutes": 10
        },
        "LibraryBooks": {
          "Prefix": "library:books",
          "TtlInMinutes": 5
        },
        "BookDetails": {
          "Prefix": "book:details",
          "TtlInMinutes": 30
        },
        "VersionKey": "books:cache"
      },
      "Reports": {
        "VersionKey": "reports:cache",
        "ReportsList": {
          "Prefix": "reports:list",
          "TtlInMinutes": 1440
        }
      }
    },
    "Minio": {
      "Endpoint": "minio:9000",
      "AccessKey": "minioadmin",
      "SecretKey": "minioadmin",
      "BucketName": "reports",
      "ReportsBucketName": "reports",
      "LibraryReportsBucketName": "library-reports"
    },
    "RabbitMQ": {
      "Host": "rabbitmq",
      "User": "guest",
      "Password": "guest",
      "Port": 5672,
      "AppName": "library",
      "Library": {
        "ExchangeName": "library.exchange",
        "BookCreate": {
          "QueueName": "book.create.queue",
          "RoutingKey": "book.create.key"
        },
        "BookArchive": {
          "QueueName": "book.archive.queue",
          "RoutingKey": "book.archive.key"
        },
        "BookBorrow": {
          "QueueName": "book.borrow.queue",
          "RoutingKey": "book.borrow.key"
        },
        "BookReturn": {
          "QueueName": "book.return.queue",
          "RoutingKey": "book.return.key"
        },
        "ReaderCreate": {
          "QueueName": "reader.create.queue",
          "RoutingKey": "reader.create.key"
        },
        "ReaderClose": {
          "QueueName": "reader.close.queue",
          "RoutingKey": "reader.close.key"
        }
      },
      "Reports": {
        "QueueName": "reports.queue",
        "Exchange": "reports.exchange",
        "RoutingKey": "reports.create.key"
      }
    },
    "Email": {
      "SmtpServer": "smtp4dev",
      "SmtpPort": 25,
      "UseSsl": false,
      "SenderName": "Библиотека",
      "SenderEmail": "noreply@library.local",
      "AdminEmails": [ "garaeilda122@gmail.com" ]
    },
    "EmailTemplates": {
      "ReturnReminder": {
        "SubjectTemplate": "Напоминание о возврате книги: \"{BookTitle}\"",
        "DaysBeforeDueDate": 3,
        "LibraryName": "Городская библиотека",
        "LibraryAddress": "ул. Библиотечная, д. 1",
        "LibraryPhone": "+7 (800) 000-00-00",
        "WorkingHours": "Пн-Пт 9:00-20:00, Сб-Вс 10:00-18:00"
      },
      "WeeklyReport": {
        "SubjectTemplate": "Еженедельный отчет библиотеки за период {StartDate} - {EndDate}",
        "AdminEmails": [ "garaeilda122@gmail.com" ],
        "ReportRetentionDays": 90
      }
    },
    "Jobs": {
      "Jobs": {
        "ReturnReminders": {
          "CronExpression": "0 0 6 * * ?",
          "MaxRetries": 3,
          "TimeoutMinutes": 30
        },
        "WeeklyReport": {
          "CronExpression": "0 0 5 ? * MON",
          "MaxRetries": 3,
          "TimeoutMinutes": 60
        },
        "ArchiveBooks": {
          "CronExpression": "0 0 0 1 * ?",
          "MaxRetries": 3,
          "TimeoutMinutes": 60
        }
      }
    },
    "Archive": {
      "YearsWithoutBorrow": 3,
      "MaxBooksPerRun": 100
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
